\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Geometric contrast between nested coupling and clock synchronization for $K=3$ bands. (a) Under nested coupling, trajectories can explore the full 2-torus $\mathbb  {T}^2$ of relative phase offsets $(\psi _1, \psi _2)$. (b) Under clock synchronization, all relative phases are deterministic functions of a single base clock, constraining the system to a 1-dimensional closed curve (red). The clock curve cannot access most of the torus---this is the geometric origin of dimensional collapse.}}{12}{figure.1}\protected@file@percent }
\newlabel{fig:torus_clock}{{1}{12}{Geometric contrast between nested coupling and clock synchronization for $K=3$ bands. (a) Under nested coupling, trajectories can explore the full 2-torus $\T ^2$ of relative phase offsets $(\psi _1, \psi _2)$. (b) Under clock synchronization, all relative phases are deterministic functions of a single base clock, constraining the system to a 1-dimensional closed curve (red). The clock curve cannot access most of the torus---this is the geometric origin of dimensional collapse}{figure.1}{}}
