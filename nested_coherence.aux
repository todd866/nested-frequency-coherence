\newlabel{tab:comparison}{{1}{14}{Fisher information structure under different oscillatory architectures. \textsuperscript {\dag }Requires direct observation of each band. \textsuperscript {*}With $N \geq K-1$ informative observations; coupling makes slow phases enter the fast-band likelihood}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Fisher rank under nested coupling vs.\ clock synchronization. (a) Rank of Fisher information matrix as a function of sample size $N$. The nested model achieves full rank $K-1=3$ once $N \geq K-1$; the clock model is constrained to rank 1 regardless of $N$. (b) Eigenvalue spectrum for the nested model with $N=10$ observations, showing three nonzero eigenvalues corresponding to the three identifiable slow-phase parameters. \textbf  {Simulation parameters:} $K=4$ bands with slow modulators at 2, 5, 8 Hz and carrier at 40 Hz; modulation depths $\alpha _j = 0.3$; noise $\sigma = 0.1$; observations uniformly sampled on $[0, 1]$ s with small random jitter.}}{14}{figure.2}\protected@file@percent }
\newlabel{fig:fisher_rank}{{2}{14}{Fisher rank under nested coupling vs.\ clock synchronization. (a) Rank of Fisher information matrix as a function of sample size $N$. The nested model achieves full rank $K-1=3$ once $N \geq K-1$; the clock model is constrained to rank 1 regardless of $N$. (b) Eigenvalue spectrum for the nested model with $N=10$ observations, showing three nonzero eigenvalues corresponding to the three identifiable slow-phase parameters. \textbf {Simulation parameters:} $K=4$ bands with slow modulators at 2, 5, 8 Hz and carrier at 40 Hz; modulation depths $\alpha _j = 0.3$; noise $\sigma = 0.1$; observations uniformly sampled on $[0, 1]$ s with small random jitter}{figure.2}{}}
